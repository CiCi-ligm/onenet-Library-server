<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.BookMapper">
	<select id="queryAll" resultType="book">
		select * 
			from bm_book
	</select>
	<insert id="addBook" parameterType="book">
		<selectKey resultType="long" keyProperty="id" order="BEFORE">
		 	select bmBook_seq.nextval from dual	
		</selectKey>
		insert into 
			bm_book(id,bookName,publishHouse,publishTime,num)
			values(#{id},#{bookName},#{publishHouse},#{publishTime},#{num})
	</insert>
	<update id="updateBook" parameterType="book">
		update bm_book
			set num = #{num}
			 where bookName = #{bookName}
	</update>
	<delete id="deleteBook" parameterType="book">
		delete from
			bm_book
			where bookName = #{bookName}
	</delete>
	<select id="selectBook" parameterType="String" resultType="book">
		select * 
			from bm_book
			where bookName = #{bookName}
	</select>
</mapper>